# Copy this file to .env.local and fill in your keys
# cp .env.local.example .env.local

# Login password for the app (choose anything)
PENTEST_KEY=your-secret-password-here

# Anthropic — for executive discovery parsing and salutation inference
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# Serper — for Google search (executive images, LinkedIn, leadership pages)
# https://serper.dev
SERPER_API_KEY=

# AssemblyAI — for speaker diarization (identifies who is the executive)
# https://www.assemblyai.com
ASSEMBLYAI_API_KEY=

# Cartesia — for voice cloning
# https://play.cartesia.ai
CARTESIA_API_KEY=
